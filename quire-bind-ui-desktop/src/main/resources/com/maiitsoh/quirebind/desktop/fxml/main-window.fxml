<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.maiitsoh.quirebind.desktop.controller.MainController"
            styleClass="root-pane">

    <!-- ═══ Menu bar ════════════════════════════════════════════════════════ -->
    <top>
        <MenuBar>
            <Menu text="_File">
                <MenuItem text="_New Project"  onAction="#handleMenuNewProject"/>
                <MenuItem text="_Open PDF…"    onAction="#handleMenuOpenPdf"/>
                <SeparatorMenuItem/>
                <MenuItem text="E_xit"         onAction="#handleMenuExit"/>
            </Menu>
            <Menu text="_Help">
                <MenuItem text="_Binding Guides" onAction="#handleMenuGuides"/>
                <SeparatorMenuItem/>
                <MenuItem text="_About QuireBind" onAction="#handleAbout"/>
            </Menu>
        </MenuBar>
    </top>

    <!-- ═══ Wizard ══════════════════════════════════════════════════════════ -->
    <center>
        <VBox styleClass="wizard-container">

            <!-- Step indicator -->
            <HBox styleClass="step-indicator">
                <Label fx:id="stepIndicatorLabel" text="Step 1 of 4"
                       styleClass="step-indicator-label"/>
            </HBox>

            <!-- Step panels -->
            <StackPane fx:id="wizardStack" styleClass="wizard-stack" VBox.vgrow="ALWAYS">

                <!-- ─── Step 1: Load ──────────────────────────────────────── -->
                <VBox fx:id="stepLoad" styleClass="wizard-step" spacing="12">
                    <Label text="Load Source" styleClass="step-title"/>
                    <Label text="Choose a single PDF or a .quire batch file."
                           styleClass="step-description" wrapText="true"/>
                    <Separator/>

                    <!-- Mode toggle -->
                    <HBox spacing="0" styleClass="mode-toggle-bar">
                        <ToggleButton fx:id="singlePdfToggle" text="Single PDF"
                                      styleClass="mode-toggle-left"/>
                        <ToggleButton fx:id="batchToggle"     text="Batch (.quire)"
                                      styleClass="mode-toggle-right"/>
                    </HBox>

                    <!-- Single PDF pane -->
                    <VBox fx:id="singlePdfPane" spacing="8">
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <TextField fx:id="pdfPathField" promptText="No PDF selected"
                                       editable="false" HBox.hgrow="ALWAYS"/>
                            <Button text="Browse…" onAction="#handleBrowseInput"
                                    styleClass="action-button"/>
                        </HBox>
                        <Label fx:id="pageCountLabel" styleClass="info-label"/>
                    </VBox>

                    <!-- Batch pane -->
                    <VBox fx:id="batchPane" spacing="8" visible="false" managed="false">
                        <Label text="Select a .quire batch config to process multiple jobs."
                               styleClass="step-description" wrapText="true"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <TextField fx:id="quirePathField" promptText="No .quire file selected"
                                       editable="false" HBox.hgrow="ALWAYS"/>
                            <Button text="Browse…" onAction="#handleBrowseQuire"
                                    styleClass="action-button"/>
                        </HBox>
                        <Label fx:id="jobCountLabel" styleClass="info-label"/>
                    </VBox>
                </VBox>

                <!-- ─── Step 2: Options ───────────────────────────────────── -->
                <VBox fx:id="stepOptions" styleClass="wizard-step" spacing="10"
                      visible="false" managed="false">
                    <Label text="Binding Options" styleClass="step-title"/>
                    <Label text="Configure the imposition settings for your binding technique."
                           styleClass="step-description" wrapText="true"/>
                    <Separator/>

                    <!-- Two-column layout: form left, diagram right -->
                    <HBox spacing="20" VBox.vgrow="ALWAYS">

                        <!-- Form -->
                        <VBox spacing="8" minWidth="240">
                            <GridPane hgap="10" vgap="8">
                                <columnConstraints>
                                    <ColumnConstraints minWidth="150" maxWidth="170"/>
                                    <ColumnConstraints hgrow="ALWAYS"/>
                                </columnConstraints>

                                <Label text="Binding technique:"
                                       GridPane.rowIndex="0" GridPane.columnIndex="0"
                                       styleClass="field-label"/>
                                <ComboBox fx:id="techniqueCombo"
                                          GridPane.rowIndex="0" GridPane.columnIndex="1"
                                          maxWidth="Infinity"/>

                                <Label text="Paper size:"
                                       GridPane.rowIndex="1" GridPane.columnIndex="0"
                                       styleClass="field-label"/>
                                <ComboBox fx:id="paperSizeCombo"
                                          GridPane.rowIndex="1" GridPane.columnIndex="1"
                                          maxWidth="Infinity"/>

                                <Label fx:id="sigSizeLabel" text="Sheets per signature:"
                                       GridPane.rowIndex="2" GridPane.columnIndex="0"
                                       styleClass="field-label"/>
                                <Spinner fx:id="sigSizeSpinner"
                                         GridPane.rowIndex="2" GridPane.columnIndex="1"
                                         maxWidth="100"/>

                                <Label text="Reading direction:"
                                       GridPane.rowIndex="3" GridPane.columnIndex="0"
                                       styleClass="field-label"/>
                                <ComboBox fx:id="directionCombo"
                                          GridPane.rowIndex="3" GridPane.columnIndex="1"
                                          maxWidth="Infinity"/>

                                <Label text="Paper thickness (mm):"
                                       GridPane.rowIndex="4" GridPane.columnIndex="0"
                                       styleClass="field-label"/>
                                <TextField fx:id="thicknessField"
                                           GridPane.rowIndex="4" GridPane.columnIndex="1"
                                           promptText="blank = no creep" maxWidth="140"/>
                            </GridPane>

                            <!-- Padding position (group C only) -->
                            <VBox fx:id="paddingPositionPane" spacing="4"
                                  visible="false" managed="false">
                                <Label text="Blank padding position:" styleClass="field-label"/>
                                <HBox spacing="0" styleClass="mode-toggle-bar">
                                    <ToggleButton fx:id="padAfterToggle" text="After content"
                                                  styleClass="mode-toggle-left"/>
                                    <ToggleButton fx:id="padBeforeToggle" text="Before content"
                                                  styleClass="mode-toggle-right"/>
                                </HBox>
                                <Label text="Where blank pages are added to complete the last signature."
                                       styleClass="step-description" wrapText="true"/>
                            </VBox>
                        </VBox>

                        <!-- Diagram -->
                        <StackPane fx:id="diagramPane" styleClass="diagram-pane"
                                   HBox.hgrow="ALWAYS" minWidth="270" minHeight="200"/>

                    </HBox>
                </VBox>

                <!-- ─── Step 3: Preview / edit ────────────────────────────── -->
                <VBox fx:id="stepPreview" styleClass="wizard-step" spacing="8"
                      visible="false" managed="false">
                    <Label text="Page Sequence" styleClass="step-title"/>
                    <Label text="Review and edit pages before imposition."
                           styleClass="step-description" wrapText="true"/>
                    <Separator/>

                    <!-- Matter + thumbnail bar -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Front matter:" styleClass="field-label"/>
                        <Spinner fx:id="frontMatterSpinner" maxWidth="72" editable="true"/>
                        <Label text="pages" styleClass="step-description"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Rear matter:" styleClass="field-label"/>
                        <Spinner fx:id="rearMatterSpinner" maxWidth="72" editable="true"/>
                        <Label text="pages" styleClass="step-description"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <javafx.scene.control.CheckBox fx:id="thumbnailCheck"
                                                       text="Show thumbnails"/>
                    </HBox>

                    <!-- Editing toolbars -->
                    <HBox spacing="6">
                        <Button text="+ Blank before" onAction="#handleAddBlankBefore"
                                styleClass="action-button"/>
                        <Button text="+ Blank after"  onAction="#handleAddBlankAfter"
                                styleClass="action-button"/>
                        <Button text="✕ Remove"       onAction="#handleRemovePage"
                                styleClass="action-button"/>
                        <Button text="↑ Move up"      onAction="#handleMovePageUp"
                                styleClass="action-button"/>
                        <Button text="↓ Move down"    onAction="#handleMovePageDown"
                                styleClass="action-button"/>
                        <Button text="+ Deco front"   onAction="#handleAddDecorativeFront"
                                styleClass="action-button"/>
                        <Button text="+ Deco rear"    onAction="#handleAddDecorativeRear"
                                styleClass="action-button"/>
                    </HBox>

                    <!-- SplitPane: page list | side panel -->
                    <javafx.scene.control.SplitPane dividerPositions="0.62"
                                                    VBox.vgrow="ALWAYS">
                        <ListView fx:id="pageListView" styleClass="page-list"/>
                        <VBox styleClass="thumbnail-panel" spacing="8" minWidth="170">
                            <Label text="Preview" styleClass="section-label"/>
                            <StackPane styleClass="thumbnail-container" VBox.vgrow="ALWAYS">
                                <Label fx:id="thumbnailPlaceholder" text="Select a page"
                                       styleClass="step-description"/>
                                <javafx.scene.image.ImageView fx:id="thumbnailView"
                                    fitWidth="180" preserveRatio="true"
                                    visible="false" managed="false"/>
                            </StackPane>
                            <Separator/>
                            <Label text="Page label:" styleClass="field-label"/>
                            <TextField fx:id="pageLabelField" promptText="e.g. Title page"/>
                            <Button text="Set label" onAction="#handleSetPageLabel"
                                    styleClass="action-button" maxWidth="Infinity"/>
                        </VBox>
                    </javafx.scene.control.SplitPane>

                    <Label fx:id="overflowLabel" styleClass="overflow-label" wrapText="true"/>
                    <Label fx:id="previewSummaryLabel" styleClass="summary-label"/>
                </VBox>

                <!-- ─── Step 4: Export ────────────────────────────────────── -->
                <VBox fx:id="stepExport" styleClass="wizard-step" spacing="12"
                      visible="false" managed="false">
                    <Label text="Export" styleClass="step-title"/>
                    <Label text="Set output marks, review the imposition, then export or save as a template."
                           styleClass="step-description" wrapText="true"/>
                    <Separator/>

                    <!-- Two-column: marks + table -->
                    <HBox spacing="20" VBox.vgrow="ALWAYS">

                        <!-- Marks, numbering + export controls -->
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    styleClass="export-scroll">
                            <VBox spacing="10" minWidth="220">
                                <padding><Insets top="2" right="4" bottom="2" left="0"/></padding>
                                <Label text="Output Marks" styleClass="section-label"/>
                                <CheckBox fx:id="foldLinesCheck"   text="Fold lines"/>
                                <CheckBox fx:id="stitchMarksCheck" text="Stitch marks"/>
                                <CheckBox fx:id="sewingHolesCheck" text="Sewing holes"/>
                                <CheckBox fx:id="trimLinesCheck"   text="Trim lines"/>
                                <Separator/>
                                <Label text="Page Numbering" styleClass="section-label"/>
                                <GridPane hgap="6" vgap="5">
                                    <columnConstraints>
                                        <ColumnConstraints minWidth="90" maxWidth="110"/>
                                        <ColumnConstraints hgrow="ALWAYS"/>
                                        <ColumnConstraints minWidth="64" maxWidth="72"/>
                                    </columnConstraints>
                                    <!-- Header row -->
                                    <Label text=""
                                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                    <Label text="Style"
                                           GridPane.rowIndex="0" GridPane.columnIndex="1"
                                           styleClass="field-label"/>
                                    <Label text="Start №"
                                           GridPane.rowIndex="0" GridPane.columnIndex="2"
                                           styleClass="field-label"/>
                                    <!-- Front matter -->
                                    <Label text="Front matter:"
                                           GridPane.rowIndex="1" GridPane.columnIndex="0"
                                           styleClass="field-label"/>
                                    <ComboBox fx:id="frontMatterFolioStyleCombo"
                                              GridPane.rowIndex="1" GridPane.columnIndex="1"
                                              maxWidth="Infinity"/>
                                    <Spinner fx:id="frontStartNumberSpinner"
                                             GridPane.rowIndex="1" GridPane.columnIndex="2"
                                             maxWidth="64"/>
                                    <!-- Body -->
                                    <Label text="Body:"
                                           GridPane.rowIndex="2" GridPane.columnIndex="0"
                                           styleClass="field-label"/>
                                    <ComboBox fx:id="bodyFolioStyleCombo"
                                              GridPane.rowIndex="2" GridPane.columnIndex="1"
                                              maxWidth="Infinity"/>
                                    <Spinner fx:id="startNumberSpinner"
                                             GridPane.rowIndex="2" GridPane.columnIndex="2"
                                             maxWidth="64"/>
                                    <!-- Rear matter -->
                                    <Label text="Rear matter:"
                                           GridPane.rowIndex="3" GridPane.columnIndex="0"
                                           styleClass="field-label"/>
                                    <ComboBox fx:id="rearMatterFolioStyleCombo"
                                              GridPane.rowIndex="3" GridPane.columnIndex="1"
                                              maxWidth="Infinity"/>
                                    <Spinner fx:id="rearStartNumberSpinner"
                                             GridPane.rowIndex="3" GridPane.columnIndex="2"
                                             maxWidth="64"/>
                                    <!-- Position -->
                                    <Label text="Position:"
                                           GridPane.rowIndex="4" GridPane.columnIndex="0"
                                           styleClass="field-label"/>
                                    <ComboBox fx:id="folioPositionCombo"
                                              GridPane.rowIndex="4" GridPane.columnIndex="1"
                                              GridPane.columnSpan="2" maxWidth="Infinity"/>
                                </GridPane>
                                <CheckBox fx:id="suppressFirstFolioCheck"
                                          text="Suppress folio on first page"/>
                                <Separator/>
                                <Label text="Output File" styleClass="section-label"/>
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <TextField fx:id="outputPathField"
                                               promptText="No output chosen"
                                               editable="false" HBox.hgrow="ALWAYS"/>
                                    <Button text="Browse…" onAction="#handleBrowseOutput"
                                            styleClass="action-button"/>
                                </HBox>
                                <Button fx:id="exportButton" text="Export PDF"
                                        onAction="#handleExport"
                                        styleClass="primary-button" maxWidth="Infinity"/>
                                <Button text="Save as .quire template…"
                                        onAction="#handleSaveTemplate"
                                        styleClass="action-button" maxWidth="Infinity"/>
                                <Label fx:id="exportResultLabel" styleClass="success-label"
                                       wrapText="true"/>
                            </VBox>
                        </ScrollPane>

                        <!-- Imposition summary table -->
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Imposition Summary" styleClass="section-label"/>
                            <TableView fx:id="signaturesTable" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colZone"       text="Zone"   prefWidth="90"/>
                                    <TableColumn fx:id="colSigIndex"   text="#"      prefWidth="44"/>
                                    <TableColumn fx:id="colPageCount"  text="Pages"  prefWidth="70"/>
                                    <TableColumn fx:id="colSheetCount" text="Sheets" prefWidth="70"/>
                                    <TableColumn fx:id="colCreep"      text="Max creep" prefWidth="100"/>
                                </columns>
                                <placeholder><Label text="Run imposition to see results"/></placeholder>
                            </TableView>
                        </VBox>

                    </HBox>
                </VBox>

            </StackPane>

            <!-- Navigation bar -->
            <HBox styleClass="wizard-nav" spacing="8" alignment="CENTER_RIGHT">
                <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="backButton" text="← Back"  onAction="#handleBack"
                        disable="true"/>
                <Button fx:id="nextButton" text="Next →"  onAction="#handleNext"
                        styleClass="primary-button"/>
            </HBox>

        </VBox>
    </center>

    <!-- ═══ Status bar ═══════════════════════════════════════════════════════ -->
    <bottom>
        <HBox styleClass="status-bar">
            <padding><Insets top="4" right="12" bottom="4" left="12"/></padding>
            <Label fx:id="statusLabel" text="Ready." styleClass="status-label"/>
        </HBox>
    </bottom>

</BorderPane>
