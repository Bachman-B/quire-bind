# Maintainer: QuireBind Contributors <https://github.com/Bachman-B/quire-bind>
pkgname=quirebind
pkgver=1.1.0
pkgrel=1
pkgdesc="PDF imposition tool for preparing documents for hand bookbinding"
arch=('x86_64')
url="https://github.com/Bachman-B/quire-bind"
license=('AGPL-3.0-only')
depends=()
optdepends=('java-runtime>=21: required only if running the web JAR separately')
provides=('quirebind')
conflicts=('quirebind')

source=("QuireBind-${pkgver}-x86_64.AppImage::https://github.com/Bachman-B/quire-bind/releases/download/v${pkgver}/QuireBind-${pkgver}-x86_64.AppImage"
        "quire-bind-256.png::https://raw.githubusercontent.com/Bachman-B/quire-bind/main/quire-bind-ui-desktop/src/main/resources/com/maiitsoh/quirebind/desktop/icons/quire-bind-256.png")
sha256sums=('SKIP'
            'SKIP')
options=('!strip')

package() {
    install -Dm755 "QuireBind-${pkgver}-x86_64.AppImage" \
        "${pkgdir}/opt/quirebind/QuireBind.AppImage"

    # Wrapper script so the binary appears on PATH
    install -dm755 "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/quirebind" << 'EOF'
#!/bin/sh
exec /opt/quirebind/QuireBind.AppImage "$@"
EOF
    chmod 755 "${pkgdir}/usr/bin/quirebind"

    # Desktop entry
    install -Dm644 /dev/stdin "${pkgdir}/usr/share/applications/quirebind.desktop" << 'EOF'
[Desktop Entry]
Name=QuireBind
GenericName=Bookbinding Imposition Tool
Comment=Prepare PDF files for hand bookbinding
Exec=quirebind
Icon=quirebind
Type=Application
Categories=Office;Graphics;
Keywords=bookbinding;imposition;pdf;print;
StartupNotify=true
EOF

    # App icon
    install -Dm644 "quire-bind-256.png" \
        "${pkgdir}/usr/share/icons/hicolor/256x256/apps/quirebind.png"
}
